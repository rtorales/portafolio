{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/profile/**",
              "ui_kits/portfolio/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Space Grotesk|Hanken Grotesk|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Space Grotesk, Hanken Grotesk, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|alt|size|ring|style|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: src, alt, size, ring, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|dot|pulse|style|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, dot, pulse, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:success|gold|accent|neutral)$/]",
        "message": "<Badge> tone must be one of 'success' | 'gold' | 'accent' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|href|icon|iconRight|disabled|onClick|type|style|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, href, icon, iconRight, disabled, onClick, type, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|accent|white|outline|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'accent' | 'white' | 'outline' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:interactive|accent|tone|padding|style|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: interactive, accent, tone, padding, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:card|subtle)$/]",
        "message": "<Card> tone must be one of 'card' | 'subtle'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ContactCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|href|tone|style|children|key|ref|className|style|children)$/]",
        "message": "<ContactCard> doesn't accept that prop. Declared props: icon, href, tone, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='ContactCard'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:onDark|light)$/]",
        "message": "<ContactCard> tone must be one of 'onDark' | 'light'."
      },
      {
        "selector": "JSXOpeningElement[name.name='LangBar'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|level|value|style|key|ref|className|style|children)$/]",
        "message": "<LangBar> doesn't accept that prop. Declared props: name, level, value, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionLabel'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|style|children|key|ref|className|style|children)$/]",
        "message": "<SectionLabel> doesn't accept that prop. Declared props: tone, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionLabel'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:light|onDark)$/]",
        "message": "<SectionLabel> tone must be one of 'light' | 'onDark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SkillCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|title|skills|style|key|ref|className|style|children)$/]",
        "message": "<SkillCard> doesn't accept that prop. Declared props: icon, title, skills, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|suffix|label|style|key|ref|className|style|children)$/]",
        "message": "<StatItem> doesn't accept that prop. Declared props: value, suffix, label, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|style|children|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: tone, style, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:solid|onDark|accent)$/]",
        "message": "<Tag> tone must be one of 'solid' | 'onDark' | 'accent'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TimelineItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:company|role|period|context|bullets|current|currentLabel|style|key|ref|className|style|children)$/]",
        "message": "<TimelineItem> doesn't accept that prop. Declared props: company, role, period, context, bullets, current, currentLabel, style."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
